{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "sh -c 'PYTHONPATH=. uvicorn backend.main:app --host 0.0.0.0 --port $PORT || uvicorn main:app --host 0.0.0.0 --port $PORT'",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
